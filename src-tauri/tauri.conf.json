{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Chords",
  "version": "0.1.0",
  "identifier": "com.leonsilicon.chords",
  "build": {
    "beforeDevCommand": "bun run vite-dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "settings",
        "title": "Chords Settings",
        "width": 420,
        "height": 320,
        "visible": false,
        "resizable": true,
        "center": true
      },
      {
        "label": "overlay",
        "title": "Chords Overlay",
        "width": 1280,
        "height": 800,
        "visible": false,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "maximizable": false,
        "minimizable": false,
        "visibleOnAllWorkspaces": true,
        "shadow": false
      },
      {
        "label": "indicator",
        "title": "Chord Mode Indicator",
        "width": 240,
        "height": 44,
        "visible": false,
        "transparent": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "maximizable": false,
        "minimizable": false,
        "visibleOnAllWorkspaces": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "macOS": {
      "signingIdentity": "Apple Development: Leon Si (4HXF7T46Q6)"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
